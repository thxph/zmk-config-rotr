#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/rgb.h>
#include <dt-bindings/zmk/default_layer.h>

/ {
	behaviors {
		enc: enc {
			compatible = "zmk,behavior-sensor-rotate-key-press";
			label = "ENC";
			#sensor-binding-cells = <2>;
			triggers-per-rotation = <30>;
		};

		mid_lt: middle_layer_tap {
			compatible = "zmk,behavior-hold-tap";
			label = "MID_LT";
			flavor = "hold-preferred";
			tapping-term-ms = <200>;
			bindings = <&mo>, <&kp>;
			#binding-cells = <2>;
		};
	};

	macros {
		/*
		 * Cycle the default layer AND ensure the strip is on. RGB_ON persists
		 * on=true to NVS, but Zephyr NVS skips writes when the value is
		 * unchanged, so this only touches flash the first time. Per-layer color
		 * still comes from the ephemeral DEFAULTLAYER effect, not a saved color.
		 */
		cyc_prev: cyc_prev {
			compatible = "zmk,behavior-macro";
			label = "CYC_PREV";
			#binding-cells = <0>;
			bindings = <&rgb_ug RGB_ON>, <&def LYRDN>;
		};

		cyc_next: cyc_next {
			compatible = "zmk,behavior-macro";
			label = "CYC_NEXT";
			#binding-cells = <0>;
			bindings = <&rgb_ug RGB_ON>, <&def LYRUP>;
		};
	};

	combos {
		compatible = "zmk,combos";

		/* Bootloader = press both outer keys together, only on the reset layer. */
		combo_boot {
			timeout-ms = <100>;
			key-positions = <0 2>;
			layers = <2>;
			bindings = <&bootloader>;
		};
	};

	keymap {
		compatible = "zmk,keymap";

		/*
		 * Layers 0-2 are content layers cycled by &def (the fork's default-layer
		 * behavior). Their color comes from the DEFAULTLAYER underglow effect,
		 * which reads zmk_keymap_layer_default() and the ledoverride/r/g/b props
		 * below. Layer 3 is the control layer reached by holding the middle key.
		 */
		base_layer {
			bindings = <&kp DOWN &mid_lt 3 LG(B) &kp UP>;
			sensor-bindings = <&enc RIGHT LEFT>;
			/* white */
			ledoverride;
			r = <255>;
			g = <255>;
			b = <255>;
		};

		second_layer {
			bindings = <&kp DOWN &mid_lt 3 LG(B) &kp UP>;
			sensor-bindings = <&enc LS(RIGHT) LS(LEFT)>;
			/* orange */
			ledoverride;
			r = <255>;
			g = <90>;
			b = <0>;
		};

		reset_layer {
			/*
			 * Bootloader is the LEFT+RIGHT combo above, scoped to this layer, so it
			 * only fires on a deliberate two-key press. To leave without flashing,
			 * hold middle (control layer) and tap left/right to cycle away.
			 */
			bindings = <&trans &mid_lt 3 LG(B) &trans>;
			/* red */
			ledoverride;
			r = <255>;
			g = <0>;
			b = <0>;
		};

		control_layer {
			/*
			 * Reached by holding the middle key. Tap left = previous layer,
			 * right = next layer, with wraparound. &def changes the default layer
			 * (re-rendering the LED) without deactivating this held layer, so you
			 * can keep middle held and tap repeatedly to cycle.
			 */
			bindings = <&cyc_prev &trans &cyc_next>;
		};
	};
};
